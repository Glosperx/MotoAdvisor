# Copy to .env and fill in real values before running docker-compose up.
# Never commit .env to git.

# ── Database ────────────────────────────────────────────────────────────────
# Password for the postgres:16-alpine container. Username and DB name are
# fixed as "motoadvisor"; the host is derived from the container name.
# Use: openssl rand -base64 32
DB_PASSWORD=changeme

# ── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Use: openssl rand -base64 48
JWT_KEY=replace-this-with-a-random-secret-min-32-chars!!
JWT_ISSUER=MotoAdvisorAPI
JWT_AUDIENCE=MotoAdvisorClient
JWT_EXPIRES_MINUTES=60

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://motoadvisor.student-dev.ro

# ── Gemini AI ────────────────────────────────────────────────────────────────
# Optional. Leave empty to disable AI features.
GEMINI_API_KEY=
